#!/usr/bin/env bash
# lab-status — Quick health check for the security lab.
# Run on session start (and on Monday after the pre-stage).
# Exits 0 if all green, 1 if any red.

set -uo pipefail

LAB=${HACKING_LAB}
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PASS=0
FAIL=0
WARN=0

ok()   { echo -e "${GREEN}OK${NC}    $1"; PASS=$((PASS+1)); }
fail() { echo -e "${RED}FAIL${NC}  $1"; FAIL=$((FAIL+1)); }
warn() { echo -e "${YELLOW}WARN${NC}  $1"; WARN=$((WARN+1)); }

echo "=================================================="
echo "Lab status — $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "=================================================="

echo
echo "## Plan & docs"
test -f "$LAB/PLAN.md" && ok "PLAN.md present" || fail "PLAN.md missing"
test -f "$LAB/AGENTS.md" && ok "AGENTS.md present" || fail "AGENTS.md missing"
test -f "$LAB/scope.yaml" && ok "scope.yaml present" || fail "scope.yaml missing"
test -f "$LAB/PRE_STAGE_REPORT.md" && ok "PRE_STAGE_REPORT.md present" || warn "PRE_STAGE_REPORT.md missing"

echo
echo "## Skills drafts (${HACKING_LAB}/skills/)"
SKILL_COUNT=$(find $LAB/skills -name SKILL.md 2>/dev/null | wc -l)
if [ "$SKILL_COUNT" -ge 12 ]; then
  ok "Skill drafts: $SKILL_COUNT"
else
  warn "Skill drafts: $SKILL_COUNT (expected 12+)"
fi

echo
echo "## Content (cloned repos)"
test -d "$LAB/sandboxes/vulhub" && ok "vulhub: $(du -sh $LAB/sandboxes/vulhub 2>/dev/null | cut -f1)" || fail "vulhub missing"
test -d "$LAB/wordlists/SecLists" && ok "SecLists: $(du -sh $LAB/wordlists/SecLists 2>/dev/null | cut -f1)" || fail "SecLists missing"
test -d "$LAB/wordlists/PayloadsAllTheThings" && ok "PayloadsAllTheThings: $(du -sh $LAB/wordlists/PayloadsAllTheThings 2>/dev/null | cut -f1)" || fail "PayloadsAllTheThings missing"
test -f "$LAB/wordlists/raft-medium-directories.txt" && ok "assetnote wordlist present" || warn "assetnote wordlist missing"

echo
echo "## Tools (this is what Day 1 verifies)"
for t in nmap sqlmap gobuster ffuf john hashcat radare2 rizin steghide binwalk exiftool \
         nuclei httpx subfinder amass dnsx naabu massdns \
         jwt-tool angr ROPgadget shodan wafw00f vulners \
         zsteg wpscan ghidra-analyze gdb docker python3 node go cargo; do
  command -v "$t" >/dev/null 2>&1 && ok "$t" || warn "$t (not yet installed)"
done

command -v pwn >/dev/null 2>&1 && ok "pwntools (pwn)" || warn "pwntools (not yet installed)"

echo
echo "## Docker images"
docker images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | grep -E "vulnerables/web-dvwa|bkimminich/juice-shop" > /tmp/docker-images.txt
test -s /tmp/docker-images.txt && ok "DVWA + Juice Shop images present" || warn "DVWA / Juice Shop images not yet pulled"

echo
echo "## Memory layer (gbrain)"
if [ -d "$HOME/.gbrain" ]; then
  ok "gbrain directory exists"
  test -d "$HOME/.gbrain/brain.pglite" && ok "PGLite brain initialized" || warn "PGLite brain not yet initialized (run /setup-gbrain)"
else
  warn "gbrain not yet set up (run /setup-gbrain on Day 2)"
fi

echo
echo "## Caido (web proxy)"
curl -sf -o /dev/null --max-time 2 http://127.0.0.1:8080/ && ok "Caido reachable on localhost:8080" || warn "Caido not reachable (start it before Day 1)"

echo
echo "## Vault (Obsidian)"
test -d "$HOME/Documents/obsidian-vault/Cybersecurity/CTFs/<CTF_NAME>" && \
  ok "CTF folder present in vault" || warn "CTF folder missing in vault"
test -d "$HOME/Documents/obsidian-vault/Cybersecurity/Sessions" && \
  ok "Sessions folder present" || warn "Sessions folder missing"
# Tolaria artifacts
test -f "$HOME/Documents/obsidian-vault/AGENTS.md" && \
  warn "Tolaria AGENTS.md still present" || ok "Tolaria files cleaned"

echo
echo "=================================================="
echo "Summary: $PASS OK, $WARN WARN, $FAIL FAIL"
echo "=================================================="
[ "$FAIL" -eq 0 ] && exit 0 || exit 1

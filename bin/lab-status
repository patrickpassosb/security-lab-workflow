#!/usr/bin/env bash
# lab-status — Quick health check for the security lab.
# Run on session start (and on Monday after the pre-stage).
# Exits 0 if all green, 1 if any red.

set -uo pipefail

LAB="${HACKING_LAB:-$HOME/security-lab}"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PASS=0
FAIL=0
WARN=0

ok()   { echo -e "${GREEN}OK${NC}    $1"; PASS=$((PASS+1)); }
fail() { echo -e "${RED}FAIL${NC}  $1"; FAIL=$((FAIL+1)); }
warn() { echo -e "${YELLOW}WARN${NC}  $1"; WARN=$((WARN+1)); }

echo "=================================================="
echo "Lab status — $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "=================================================="

echo
echo "## Plan & docs"
test -f "$LAB/PLAN.md" && ok "PLAN.md present" || fail "PLAN.md missing"
test -f "$LAB/AGENTS.md" && ok "AGENTS.md present" || fail "AGENTS.md missing"
test -f "$LAB/scope.yaml" && ok "scope.yaml present (global)" || fail "scope.yaml missing"
test -f "$LAB/PRE_STAGE_REPORT.md" && ok "PRE_STAGE_REPORT.md present" || warn "PRE_STAGE_REPORT.md missing"

echo
echo "## Multi-engagement system"
test -d "$LAB/engagements" && ok "engagements/ directory present" || fail "engagements/ directory missing"
if [ -d "$LAB/engagements" ]; then
  ENG_COUNT=$(find "$LAB/engagements" -maxdepth 1 -name "*.yaml" -type f 2>/dev/null | wc -l)
  if [ "$ENG_COUNT" -ge 1 ]; then
    ok "Engagement scope files: $ENG_COUNT"
  else
    warn "No engagement scope files found"
  fi
  for f in "$LAB"/engagements/*.yaml; do
    [ -f "$f" ] || continue
    ok "  $(basename "$f")"
  done
fi
test -x "$LAB/bin/lab-new" && ok "lab-new executable" || warn "lab-new missing or not executable"
test -x "$LAB/bin/lab-scope" && ok "lab-scope executable" || warn "lab-scope missing or not executable"
test -x "$LAB/bin/lab-active" && ok "lab-active executable" || warn "lab-active missing or not executable"
test -d "$LAB/templates/bounty" && ok "templates/bounty/ present" || warn "templates/bounty/ missing"
test -d "$LAB/templates/cve" && ok "templates/cve/ present" || warn "templates/cve/ missing"

echo
echo "## CTF workflow helpers"
for f in "$LAB/bin/ctf-new" "$LAB/bin/ctf-evidence" "$LAB/bin/ctf-health"; do
  test -x "$f" && ok "$(basename "$f") executable" || fail "$(basename "$f") missing or not executable"
done
for f in "$LAB/templates/ctf/solve_log.md" "$LAB/templates/ctf/exploit.py" "$LAB/templates/ctf/endpoint_siblings.txt"; do
  test -f "$f" && ok "template $(basename "$f") present" || fail "template $(basename "$f") missing"
done

echo
echo "## Skills drafts (~/security-lab/skills/)"
SKILL_COUNT=$(find $LAB/skills -name SKILL.md 2>/dev/null | wc -l)
if [ "$SKILL_COUNT" -ge 15 ]; then
  ok "Skill drafts: $SKILL_COUNT"
else
  warn "Skill drafts: $SKILL_COUNT (expected 15+)"
fi

echo
echo "## Content (cloned repos)"
test -d "$LAB/sandboxes/vulhub" && ok "vulhub: $(du -sh $LAB/sandboxes/vulhub 2>/dev/null | cut -f1)" || fail "vulhub missing"
test -d "$LAB/wordlists/SecLists" && ok "SecLists: $(du -sh $LAB/wordlists/SecLists 2>/dev/null | cut -f1)" || fail "SecLists missing"
test -d "$LAB/wordlists/PayloadsAllTheThings" && ok "PayloadsAllTheThings: $(du -sh $LAB/wordlists/PayloadsAllTheThings 2>/dev/null | cut -f1)" || fail "PayloadsAllTheThings missing"
test -f "$LAB/wordlists/raft-medium-directories.txt" && ok "assetnote wordlist present" || warn "assetnote wordlist missing"

echo
echo "## Tools (this is what Day 1 verifies)"
for t in nmap sqlmap gobuster ffuf feroxbuster john hashcat radare2 rizin steghide binwalk exiftool \
         nuclei httpx subfinder amass dnsx naabu massdns jq curl \
         jwt-tool angr ROPgadget shodan wafw00f vulners \
         zsteg wpscan ghidra-analyze gdb docker python3 node go cargo sage tshark; do
  command -v "$t" >/dev/null 2>&1 && ok "$t" || warn "$t (not yet installed)"
done

command -v pwn >/dev/null 2>&1 && ok "pwntools (pwn)" || warn "pwntools (not yet installed)"
python3 -c 'import requests' >/dev/null 2>&1 && ok "python requests" || warn "python requests (not yet installed)"
python3 -c 'import z3' >/dev/null 2>&1 && ok "python z3" || warn "python z3 (not yet installed)"

echo
echo "## Docker images"
DOCKER_IMAGES_TMP="${TMPDIR:-/tmp}/lab-docker-images.txt"
docker images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | grep -E "vulnerables/web-dvwa|bkimminich/juice-shop" > "$DOCKER_IMAGES_TMP"
test -s "$DOCKER_IMAGES_TMP" && ok "DVWA + Juice Shop images present" || warn "DVWA / Juice Shop images not yet pulled"
rm -f "$DOCKER_IMAGES_TMP" 2>/dev/null

echo
echo "## Memory layer (gbrain)"
if [ -d "$HOME/.gbrain" ]; then
  ok "gbrain directory exists"
  test -d "$HOME/.gbrain/brain.pglite" && ok "PGLite brain initialized" || warn "PGLite brain not yet initialized (run /setup-gbrain)"
else
  warn "gbrain not yet set up (run /setup-gbrain on Day 2)"
fi

echo
echo "## Caido (web proxy)"
curl -sf -o /dev/null --max-time 2 http://127.0.0.1:8080/ && ok "Caido reachable on localhost:8080" || warn "Caido not reachable (start it before Day 1)"

echo
echo "## Vault (Obsidian)"
VAULT="${VAULT_DIR:-$HOME/obsidian-vault}"
if [ -d "$VAULT" ]; then
  ok "Vault directory present: $VAULT"
  test -d "$VAULT/Cybersecurity" && ok "Cybersecurity folder present" || warn "Cybersecurity folder missing in vault"
else
  warn "Vault directory not found at $VAULT (set \$VAULT_DIR if using Obsidian)"
fi

echo
echo "=================================================="
echo "Summary: $PASS OK, $WARN WARN, $FAIL FAIL"
echo "=================================================="
[ "$FAIL" -eq 0 ] && exit 0 || exit 1

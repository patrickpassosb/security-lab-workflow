#!/usr/bin/env bash
# Capture CTF evidence with timestamped output and metadata.

set -euo pipefail

LAB="${HACKING_LAB:-$HOME/security-lab}"
CHALLENGE=""
LABEL=""
FILE_PATH=""
NOTE=""

usage() {
  cat <<'EOF'
Usage:
  ctf-evidence <challenge> <label> -- <command> [args...]
  ctf-evidence <challenge> <label> --file <path> [--note <text>]
  command | ctf-evidence <challenge> <label> [--note <text>]

Writes evidence under ~/security-lab/findings/ctf/<challenge>/evidence/ and creates JSON metadata.
EOF
}

sanitize() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

[ "$#" -ge 2 ] || { usage >&2; exit 2; }
CHALLENGE="$1"
LABEL="$2"
shift 2

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --file)
      shift
      [ "$#" -gt 0 ] || { echo "[!] --file needs a value" >&2; exit 2; }
      FILE_PATH="$1"
      ;;
    --file=*)
      FILE_PATH="${1#*=}"
      ;;
    --note)
      shift
      [ "$#" -gt 0 ] || { echo "[!] --note needs a value" >&2; exit 2; }
      NOTE="$1"
      ;;
    --note=*)
      NOTE="${1#*=}"
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
  shift
done

case "$CHALLENGE" in
  *..*|*\\*|"")
    echo "[!] Invalid challenge name. Use a single folder name." >&2
    exit 2
    ;;
esac

# Auto-detect workspace root.
# 1. Check if CHALLENGE is a subdirectory of cwd (cd-then-create mode)
# 2. Walk up from cwd to find a program folder (has AGENTS.md), then look for challenges/<name>/ or findings/<name>/
# 3. Fall back to legacy global findings/<type>/<name>/ paths
WORK=""

# Mode 1: CHALLENGE is directly under cwd (e.g. ./challenges/<name>/ or ./findings/<name>/)
for SUBDIR in challenges findings; do
  CANDIDATE="$PWD/$SUBDIR/$CHALLENGE"
  if [ -d "$CANDIDATE" ]; then
    WORK="$CANDIDATE"
    break
  fi
done

# Mode 2: Walk up from cwd to find a program folder, then look for <name>/ under challenges/ or findings/
if [ -z "$WORK" ]; then
  SEARCH_DIR="$PWD"
  while [ "$SEARCH_DIR" != "/" ]; do
    if [ -f "$SEARCH_DIR/AGENTS.md" ]; then
      for SUBDIR in challenges findings; do
        CANDIDATE="$SEARCH_DIR/$SUBDIR/$CHALLENGE"
        if [ -d "$CANDIDATE" ]; then
          WORK="$CANDIDATE"
          break 2
        fi
      done
    fi
    SEARCH_DIR="$(dirname "$SEARCH_DIR")"
  done
fi

# Mode 3: Legacy global findings/<type>/<name>/ paths
if [ -z "$WORK" ]; then
  for SUBDIR in ctf bounty cve; do
    CANDIDATE="$LAB/findings/$SUBDIR/$CHALLENGE"
    if [ -d "$CANDIDATE" ]; then
      WORK="$CANDIDATE"
      break
    fi
  done
fi

if [ -z "$WORK" ]; then
  echo "[!] Missing workspace for '$CHALLENGE'. Run bin/lab-new first." >&2
  echo "    Searched: cwd subdirs, program folders (walk up), and $LAB/findings/{ctf,bounty,cve}/$CHALLENGE" >&2
  exit 2
fi
EVIDENCE_DIR="$WORK/evidence"
mkdir -p "$EVIDENCE_DIR"

STAMP="$(date -u +%Y%m%dT%H%M%SZ)-$$"
SAFE_LABEL="$(sanitize "$LABEL")"
BASE="$EVIDENCE_DIR/$STAMP-$SAFE_LABEL"
EXIT_CODE=0
MODE="stdin"
COMMAND_JSON="[]"
OUTPUT_PATH="$BASE.txt"
# SI-018: instrument command hash + duration for audit attribution.
# COMMAND_NAME is the short tool name (e.g. "nuclei", "curl") — never the
# full command line, to avoid leaking tokens/secrets in the audit log.
# COMMAND_HASH is SHA256 of the joined command args (the actual command
# run, not the lab wrapper) — lets us dedupe/diff audit entries without
# recording the raw command. DURATION_MS is measured with python's
# time.mononic() via $EPOCHREALTIME (bash 5+) for sub-ms resolution.
COMMAND_NAME=""
COMMAND_HASH=""
DURATION_MS=""

if [ -n "$FILE_PATH" ]; then
  MODE="file"
  BASENAME="$(basename "$FILE_PATH")"
  OUTPUT_PATH="$BASE-$(sanitize "$BASENAME")"
  COMMAND_NAME="cp"
  COMMAND_HASH="$(printf '%s %s' "$FILE_PATH" "$OUTPUT_PATH" | sha256sum | awk '{print $1}')"
  START_TIME="$EPOCHREALTIME"
  # T2-20: warn if the file is outside the workspace (prevent copying /etc/shadow etc.)
  WORK_ABS="$(cd "$WORK" && pwd)"
  FILE_ABS="$(cd "$(dirname "$FILE_PATH")" && pwd)/$(basename "$FILE_PATH")"
  case "$FILE_ABS" in
    "$WORK_ABS"/*) : ;;  # inside workspace — OK
    *) echo "[!] WARNING: --file path is outside the workspace ($FILE_PATH). Copying anyway, but this may include sensitive files." >&2 ;;
  esac
  # T2-51: wrap cp in set +e so failure doesn't abort before metadata/audit
  set +e
  cp "$FILE_PATH" "$OUTPUT_PATH"
  EXIT_CODE=$?
  set -e
  if [ $EXIT_CODE -ne 0 ]; then
    echo "[!] cp failed (exit $EXIT_CODE): $FILE_PATH -> $OUTPUT_PATH" >&2
  fi
  END_TIME="$EPOCHREALTIME"
  DURATION_MS="$(python3 - <<PY
start = float("${START_TIME}")
end = float("${END_TIME}")
print(int((end - start) * 1000))
PY
)"
elif [ "$#" -gt 0 ]; then
  MODE="command"
  OUTPUT_PATH="$BASE.out"
  ERR_PATH="$BASE.err"
  COMMAND_NAME="$1"
  COMMAND_HASH="$(printf '%s' "$*" | sha256sum | awk '{print $1}')"
  START_TIME="$EPOCHREALTIME"
  set +e
  "$@" > "$OUTPUT_PATH" 2> "$ERR_PATH"
  EXIT_CODE=$?
  set -e
  END_TIME="$EPOCHREALTIME"
  DURATION_MS="$(python3 - <<PY
start = float("${START_TIME}")
end = float("${END_TIME}")
print(int((end - start) * 1000))
PY
)"
  COMMAND_JSON="$(python3 - "$@" <<'PY'
import json
import sys
print(json.dumps(sys.argv[1:]))
PY
)"
else
  cat > "$OUTPUT_PATH"
fi

META_PATH="$BASE.json"
python3 - "$META_PATH" "$MODE" "$OUTPUT_PATH" "$EXIT_CODE" "$NOTE" "$COMMAND_JSON" <<'PY'
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

meta_path, mode, output_path, exit_code, note, command_json = sys.argv[1:]
try:
    command = json.loads(command_json)
except json.JSONDecodeError:
    command = []
meta = {
    "ts": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "mode": mode,
    "output": output_path,
    "exit": int(exit_code),
    "note": note,
    "command": command,
}
Path(meta_path).write_text(json.dumps(meta, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY

TARGET=""
[ -f "$WORK/target.txt" ] && TARGET="$(tr -d '\r' < "$WORK/target.txt" | head -n 1)"
ENGAGEMENT=""
[ -f "$WORK/engagement.txt" ] && ENGAGEMENT="$(tr -d '\r' < "$WORK/engagement.txt" | head -n 1)"
# SI-005: write the audit entry through the canonical lib/labutil.audit()
# so we get file locking (fcntl.flock), symlink rejection, the `agent`
# field, and json.dumps safety. Previously this opened the audit log
# directly with `>> ... .agent-audit.jsonl`, which had none of those
# guarantees and could lose the `agent` field if the inline python was
# edited. Per-writer extras `challenge` and `label` are passed through
# the canonical writer's **extra channel.
#
# SI-018: also pass command_hash (SHA256 of the command args), duration_ms
# (wall-clock duration of the command), workspace_id (UUID from
# <workspace>/.lab/workspace.json if it exists), and command (the short
# tool name — NOT the full command line, to avoid leaking secrets/tokens
# in the audit log). All four are extra fields; the canonical schema
# allows per-writer extras. Empty values are passed through; labutil.audit
# skips falsy extras so the audit entry stays clean when a workspace has
# no workspace.json or a step has no command (stdin/file modes).
PYTHONPATH="$LAB/lib" python3 -c '
import sys
import labutil
import workspace
labutil.audit(
    "ctf-evidence",
    target=sys.argv[1],
    engagement=sys.argv[2],
    challenge=sys.argv[3],
    label=sys.argv[4],
    exit_code=int(sys.argv[5]),
    command=sys.argv[6],
    command_hash=sys.argv[7],
    duration_ms=int(sys.argv[8]) if sys.argv[8] else None,
    workspace_id=sys.argv[9],
)
' "$TARGET" "$ENGAGEMENT" "$CHALLENGE" "$LABEL" "$EXIT_CODE" "$COMMAND_NAME" "$COMMAND_HASH" "$DURATION_MS" "$(PYTHONPATH="$LAB/lib" python3 -c 'import sys, workspace; print(workspace.read_workspace_id(sys.argv[1]))' "$WORK")"

echo "[+] evidence: $OUTPUT_PATH"
echo "[+] metadata: $META_PATH"
exit "$EXIT_CODE"

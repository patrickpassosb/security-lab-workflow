#!/usr/bin/env bash
# lab-install-js-recon — pre-install JS recon tools globally for bounty work.
#
# Installs: LinkFinder, SecretFinder, gf (with patterns)
# These are FILE-PROCESSING tools (you download JS, then run them locally).
# They are NOT scanners — they don't send requests to targets.
#
# Usage:
#   lab-install-js-recon          # install all
#   lab-install-js-recon --check  # check what's installed
#
# Installs to ~/.local/ (user-space, no sudo needed).

set -euo pipefail

LOCAL_BIN="$HOME/.local/bin"
LOCAL_SHARE="$HOME/.local/share"
TOOLS_DIR="$LOCAL_SHARE/js-recon"
PATTERNS_DIR="$HOME/.config/gf"

check_only=false
[[ "${1:-}" == "--check" ]] && check_only=true

check_tool() {
    local name="$1"
    local path="$2"
    if [[ -x "$path" ]]; then
        echo "  [INSTALLED] $name -> $path"
        return 0
    elif command -v "$name" &>/dev/null; then
        echo "  [INSTALLED] $name -> $(command -v "$name")"
        return 0
    else
        echo "  [MISSING]   $name"
        return 1
    fi
}

echo "=== JS Recon Tools ==="
echo

if $check_only; then
    echo "Checking installed tools:"
    check_tool "linkfinder" "$LOCAL_BIN/linkfinder" || true
    check_tool "secretfinder" "$LOCAL_BIN/secretfinder" || true
    check_tool "gf" "$LOCAL_BIN/gf" || true
    echo
    echo "gf patterns:"
    if [[ -d "$PATTERNS_DIR" ]]; then
        ls "$PATTERNS_DIR" 2>/dev/null || echo "  (none)"
    else
        echo "  $PATTERNS_DIR not found"
    fi
    exit 0
fi

mkdir -p "$LOCAL_BIN" "$TOOLS_DIR" "$PATTERNS_DIR"

# --- LinkFinder ---
echo "[1/3] LinkFinder..."
if check_tool "linkfinder" "$LOCAL_BIN/linkfinder" 2>/dev/null; then
    echo "  Already installed, skipping"
else
    cd "$TOOLS_DIR"
    if [[ ! -d LinkFinder ]]; then
        git clone --depth 1 https://github.com/GerbenJavado/LinkFinder.git 2>/dev/null || {
            echo "  [WARN] Could not clone LinkFinder (offline?)"
        }
    fi
    if [[ -d LinkFinder ]]; then
        cd LinkFinder
        pip install --user -e . 2>/dev/null || pip3 install --user -e . 2>/dev/null || {
            echo "  [WARN] Could not pip install LinkFinder"
        }
        # Create wrapper script
        cat > "$LOCAL_BIN/linkfinder" << 'WRAPPER'
#!/usr/bin/env bash
cd "$(dirname "$(readlink -f "$0")")/../share/js-recon/LinkFinder" 2>/dev/null || cd "$HOME/.local/share/js-recon/LinkFinder"
exec python3 -m linkfinder "$@"
WRAPPER
        chmod +x "$LOCAL_BIN/linkfinder"
        echo "  [OK] linkfinder installed"
    fi
fi

# --- SecretFinder ---
echo "[2/3] SecretFinder..."
if check_tool "secretfinder" "$LOCAL_BIN/secretfinder" 2>/dev/null; then
    echo "  Already installed, skipping"
else
    cd "$TOOLS_DIR"
    if [[ ! -d SecretFinder ]]; then
        git clone --depth 1 https://github.com/detectify/secretfinder.git 2>/dev/null || {
            echo "  [WARN] Could not clone SecretFinder"
        }
    fi
    if [[ -d SecretFinder ]]; then
        cat > "$LOCAL_BIN/secretfinder" << 'WRAPPER'
#!/usr/bin/env bash
exec python3 "$HOME/.local/share/js-recon/SecretFinder/SecretFinder.py" "$@"
WRAPPER
        chmod +x "$LOCAL_BIN/secretfinder"
        echo "  [OK] secretfinder installed"
    fi
fi

# --- gf (Go-based pattern matcher) ---
echo "[3/3] gf..."
if check_tool "gf" "$LOCAL_BIN/gf" 2>/dev/null; then
    echo "  Already installed, skipping"
else
    # Install gf (the Go tool)
    if command -v go &>/dev/null; then
        go install github.com/tomnomnom/gf@latest 2>/dev/null && {
            # Copy patterns
            GF_SRC="$HOME/go/pkg/mod/github.com/tomnomnom/gf@latest/examples"
            if [[ -d "$GF_SRC" ]]; then
                cp -r "$GF_SRC"/*.json "$PATTERNS_DIR/" 2>/dev/null || true
            fi
            echo "  [OK] gf installed via go"
        } || echo "  [WARN] Could not go install gf"
    else
        echo "  [WARN] Go not found — install Go first, then re-run"
    fi
fi

# Install common gf patterns if not present
if [[ ! -f "$PATTERNS_DIR/json-sec.json" ]]; then
    cat > "$PATTERNS_DIR/json-sec.json" << 'EOF'
{
    "flags": "-i",
    "pattern": "\"(api[_-]?key|secret|token|password|passwd|pwd|credential|auth[_-]?token|access[_-]?key|private[_-]?key)\"\\s*[:=]\\s*\"[^\"]+\""
}
EOF
    echo "  [OK] json-sec pattern installed"
fi
if [[ ! -f "$PATTERNS_DIR/urls.json" ]]; then
    cat > "$PATTERNS_DIR/urls.json" << 'EOF'
{
    "flags": "-o",
    "pattern": "https?://[^\"'\\s<>]+"
}
EOF
    echo "  [OK] urls pattern installed"
fi

echo
echo "=== Done ==="
echo "Make sure $LOCAL_BIN is in your PATH (add to ~/.bashrc / ~/.zshrc if not):"
echo "  export PATH=\"$LOCAL_BIN:\$PATH\""
echo
echo "Usage:"
echo "  linkfinder -i app.js -o cli > endpoints.txt"
echo "  secretfinder -i app.js -o cli > secrets.txt"
echo "  cat app.js | gf urls"
echo "  cat app.js | gf json-sec"
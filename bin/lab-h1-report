#!/usr/bin/env python3
"""lab-h1-report — HackerOne report check, review, prepare, record-submission,
status, record-outcome, assess.

Read-only and local-only commands for HackerOne report_h1.md workspaces.

Usage:
    lab-h1-report check [workspace]
    lab-h1-report review [workspace]
    lab-h1-report prepare [workspace] [--skip-review]
    lab-h1-report status [workspace]
    lab-h1-report assess [workspace]
    lab-h1-report record-submission [workspace] --package <path|id> \
        --h1-id <num> --url <url> --submitted-at <ts> [--submitted-by <id>]
    lab-h1-report record-outcome [workspace] \
        --h1-id <report-id> --state <state> \
        [--duplicate-of <original-report-id>] \
        [--duplicate-original-state <state>] \
        [--final-severity <low|medium|high|critical>] \
        [--bounty-amount <number>] [--bounty-currency <USD|EUR|...>] \
        [--notes "<free text>"] \
        [--source <human_h1_import|auto_h1_api|manual>]

There is NO submit command. No command makes a network request or subprocess
call. Final submission is a human action in the HackerOne UI; record-submission
only records what the human already did. record-outcome appends a platform
outcome event (e.g. closed-as-duplicate) to the engagement-private
<engagement>/.lab/outcomes.jsonl (gitignored). assess (SI-015) evaluates
whether submitting is a good decision — it checks the finding's platform
state, the engagement's precedent registry, and the submission thresholds
in improvement/config/submission.yaml. It returns PASS/HOLD/BLOCK and exits
0/2/1 respectively (3 for filesystem/parse errors).

check (SI-031) runs the deterministic structural + content-quality gates
(threat_model, poc, evidence_index, limitations, finding-class rules).
review (SI-031) runs the semantic/adversarial content-quality review and
prints a structured per-dimension verdict. prepare runs check, then
review, and refuses to package unless both pass (review WARN is
non-blocking; FAIL aborts). Pass --skip-review to bypass the semantic
review (backward compat for old drafts; the audit log records the bypass).

This CLI is a thin wrapper over lib/h1report.py, lib/h1review.py, and
lib/finding_events.py. Audit events are written via labutil.audit (canonical
schema, JSON-safe, no secrets in detail). Per ADR-0002, derive_finding_status()
has ONE owner: lib/finding_events.py — this CLI imports and calls it, never
reimplements it.
"""

from __future__ import annotations

import contextlib
import os
import sys
import time
from pathlib import Path

# Import shared labutil helpers and the h1report library.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))
import finding_events  # noqa: E402
import h1report  # noqa: E402
import labutil  # noqa: E402
import workspace  # noqa: E402

AUDIT_ACTION_CHECK = "h1-report-check"
AUDIT_ACTION_STATUS = "h1-report-status"
AUDIT_ACTION_PREPARE = "h1-report-prepare"
AUDIT_ACTION_RECORD = "h1-report-record-submission"
AUDIT_ACTION_RECORD_OUTCOME = "h1-report-record-outcome"
AUDIT_ACTION_ASSESS = "h1-report-assess"

# Exit codes for the assess command (SI-015). Kept here as module-level
# constants so tests can import and assert against them without hardcoding.
ASSESS_EXIT_PASS = 0
ASSESS_EXIT_BLOCK = 1
ASSESS_EXIT_HOLD = 2
ASSESS_EXIT_ERROR = 3


def _ws_id(workspace_path: Path | str | None) -> str:
    """Read the workspace UUID from <workspace>/.lab/workspace.json.

    Returns "" when the workspace has no workspace.json (older workspaces,
    or workspaces that predate SI-016). Never raises.
    """
    if not workspace_path:
        return ""
    try:
        return workspace.read_workspace_id(Path(workspace_path))
    except Exception:  # noqa: BLE001 — defensive; audit must never break
        return ""


def _audit_h1(
    action: str,
    target: str,
    engagement: str,
    exit_code: int,
    duration_ms: int,
    workspace_path: Path | str | None,
    *,
    detail: str = "",
) -> None:
    """Write an h1-report audit entry with the SI-018 instrument fields.

    Single helper so every h1-* subcommand records action, target,
    engagement, exit, duration_ms, and workspace_id with the same shape.
    `workspace_path` is the resolved workspace Path (or None on resolution
    failure) — the UUID is read from <workspace>/.lab/workspace.json.
    """
    labutil.audit(
        action,
        target=target,
        engagement=engagement,
        exit_code=exit_code,
        detail=detail,
        duration_ms=duration_ms,
        workspace_id=_ws_id(workspace_path),
    )


def _resolve_lab_root() -> Path:
    """Resolve the lab root from $HACKING_LAB (or default) and keep labutil in sync."""
    lab_root = Path(os.environ.get("HACKING_LAB", os.path.expanduser("~/security-lab")))
    # Keep labutil's audit log path in sync with the runtime lab root so that
    # audit events land in the right lab's findings/.agent-audit.jsonl even when
    # HACKING_LAB is overridden by the caller (e.g. tests).
    labutil.AUDIT_LOG_PATH = lab_root / "findings" / ".agent-audit.jsonl"
    return lab_root


def usage() -> None:
    print(__doc__)


def _print_issue(issue: h1report.Issue) -> None:
    """Print one issue line in ASCII (no ANSI escapes)."""
    level = issue.level
    if level == "ERROR":
        label = "FAIL"
    elif level == "WARN":
        label = "WARN"
    else:
        label = "INFO"
    # Keep the line ASCII-only and free of secret material (issue.message is
    # constructed to never include raw secret values).
    print(f"{label}: {issue.location}: {issue.message}")


def _summarize(issues: list[h1report.Issue]) -> tuple[int, int, int]:
    errors = sum(1 for i in issues if i.level == "ERROR")
    warns = sum(1 for i in issues if i.level == "WARN")
    infos = sum(1 for i in issues if i.level == "INFO")
    return errors, warns, infos


def cmd_check(args: list[str]) -> int:
    """Validate a report. Exit 0 if no errors, 2 for validation failures,
    1 for usage/filesystem/parse errors."""
    workspace: str | None = None
    if len(args) > 1:
        print(f"check takes at most one optional workspace argument; got: {args}", file=sys.stderr)
        return 1
    if len(args) == 1:
        workspace = args[0]

    lab_root = _resolve_lab_root()
    start_time = time.monotonic()

    # Resolve workspace + report file first (filesystem errors -> exit 1).
    try:
        ws = h1report.resolve_workspace(workspace)
        report_path = h1report.find_report_file(ws)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_CHECK, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="report file not found",
        )
        return 1

    # Parse (parse errors -> exit 1).
    try:
        report = h1report.parse_report(report_path)
    except h1report.ReportParseError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_CHECK, str(report_path), "", 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="report parse error",
        )
        return 1

    # Run validation (returns issues; ERROR level -> exit 2).
    try:
        issues = h1report.check_report(ws, lab_root=lab_root)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_CHECK, str(report_path), "", 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="filesystem error during check",
        )
        return 1
    except h1report.ReportParseError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_CHECK, str(report_path), "", 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="parse error during check",
        )
        return 1

    # Print issues (ASCII only). WARN lines are non-blocking.
    for issue in issues:
        _print_issue(issue)

    errors, warns, infos = _summarize(issues)
    print(f"SUMMARY: {errors} error(s), {warns} warning(s), {infos} info")

    engagement_name = ""
    with contextlib.suppress(Exception):  # pragma: no cover — defensive
        engagement_name = str(report.frontmatter.get("engagement", "") or "")

    duration_ms = int((time.monotonic() - start_time) * 1000)
    if errors == 0:
        print("PASS")
        _audit_h1(
            AUDIT_ACTION_CHECK, str(report_path), engagement_name, 0,
            duration_ms, ws, detail=f"pass errors={errors} warns={warns}",
        )
        return 0
    print("FAIL")
    # Do NOT put secret-bearing text into the audit detail. Only counts.
    _audit_h1(
        AUDIT_ACTION_CHECK, str(report_path), engagement_name, 2,
        duration_ms, ws, detail=f"errors={errors} warns={warns}",
    )
    return 2


AUDIT_ACTION_REVIEW = "h1-report-review"


def cmd_review(args: list[str]) -> int:
    """Run the semantic/adversarial review on a report. Exit 0 if the
    review passes (overall=pass), 0 if it warns (overall=warn — non-
    blocking, same as check), 2 if it fails (overall=fail — blocking),
    1 for usage/filesystem/parse errors.

    The review is the semantic gate (SI-031): it reads the report body
    and evidence and returns a structured per-dimension verdict.
    Deterministic structure checks (check) alone are insufficient.
    """
    workspace: str | None = None
    if len(args) > 1:
        print(f"review takes at most one optional workspace argument; got: {args}", file=sys.stderr)
        return 1
    if len(args) == 1:
        workspace = args[0]

    lab_root = _resolve_lab_root()
    start_time = time.monotonic()

    try:
        import h1review  # noqa: E402
    except Exception as e:  # pragma: no cover
        print(f"ERROR: semantic review module unavailable: {e}", file=sys.stderr)
        return 1

    try:
        ws = h1report.resolve_workspace(workspace)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_REVIEW, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="report file not found",
        )
        return 1

    try:
        result = h1review.review_report(ws, lab_root=lab_root)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_REVIEW, str(ws), "", 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="report file not found",
        )
        return 1
    except h1report.ReportParseError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_REVIEW, str(ws), "", 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="report parse error",
        )
        return 1

    print(f"REVIEW: {result.overall}")
    print(f"BLOCKING_DIMENSIONS: {result.blocking_dimensions}")
    print("DIMENSIONS:")
    for name, dim in result.dimensions.items():
        print(f"  {name}: {dim.verdict} — {dim.reason}")
    print(f"RECOMMENDATION: {result.recommendation}")

    engagement_name = ""
    with contextlib.suppress(Exception):
        report = h1report.parse_report(h1report.find_report_file(ws))
        engagement_name = str(report.frontmatter.get("engagement", "") or "")

    duration_ms = int((time.monotonic() - start_time) * 1000)
    exit_code = 0 if result.overall in ("pass", "warn") else 2
    _audit_h1(
        AUDIT_ACTION_REVIEW, str(ws), engagement_name, exit_code,
        duration_ms, ws,
        detail=f"overall={result.overall} blocking={result.blocking_dimensions}",
    )
    return exit_code


def cmd_status(args: list[str]) -> int:
    """Print report metadata + package + submission status. Exit 0 on success,
    1 on fs/parse errors."""
    workspace: str | None = None
    if len(args) > 1:
        print(f"status takes at most one optional workspace argument; got: {args}", file=sys.stderr)
        return 1
    if len(args) == 1:
        workspace = args[0]

    lab_root = _resolve_lab_root()
    start_time = time.monotonic()

    try:
        ws = h1report.resolve_workspace(workspace)
        status = h1report.status_report(ws, lab_root=lab_root)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_STATUS, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="report file not found",
        )
        return 1
    except h1report.ReportParseError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_STATUS, "", "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="report parse error",
        )
        return 1
    except OSError as e:
        # B4/B10: catch filesystem permission errors and other OS-level
        # failures so the CLI exits cleanly with an audit event instead of
        # crashing with an unhandled traceback.
        print(f"ERROR: filesystem error: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_STATUS, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="filesystem error",
        )
        return 1

    md = status.get("metadata", {}) or {}
    print(f"report: {status['report_path']}")
    print(f"title: {md.get('title', '')}")
    print(f"program: {md.get('program', '')}")
    sev = md.get("severity", {}) or {}
    if isinstance(sev, dict):
        print(f"severity: {sev.get('rating', '')} ({sev.get('score', '')})")
    else:
        print(f"severity: {sev}")
    print(f"asset_id: {md.get('asset_id', '')}")
    print(f"finding_type: {md.get('finding_type', '')}")
    print(f"engagement: {md.get('engagement', '')}")
    print(f"weakness: {md.get('weakness', '')}")

    # C2: validation state — does the report pass `check` right now?
    vstate = status.get("validation_state")
    if vstate is None:
        print("validation: unable to run (report missing or unreadable)")
    elif vstate == "PASS":
        print(f"validation: PASS ({status.get('validation_errors', 0)} errors, "
              f"{status.get('validation_warnings', 0)} warnings)")
    else:
        print(f"validation: FAIL ({status.get('validation_errors', 0)} errors, "
              f"{status.get('validation_warnings', 0)} warnings)")

    # Latest prepared package.
    latest = status.get("latest_package")
    if latest:
        print(f"package: {latest}")
        summ = status.get("package_summary") or {}
        if summ:
            print(f"package_prepared_at: {summ.get('prepared_at', '')}")
            print(f"package_attachments: {summ.get('attachments', 0)}")
        # Integrity.
        ok = status.get("integrity_ok", True)
        drift = status.get("integrity_drift", []) or []
        if ok:
            print("integrity: OK")
        else:
            print(f"integrity: DRIFT ({', '.join(drift) if drift else 'unknown'})")
        # Source drift.
        if status.get("source_drifted"):
            print("source_drifted: true (workspace report_h1.md changed since prepare)")
        else:
            print("source_drifted: false")
        # Record.
        if status.get("record_exists"):
            print(f"record: {latest}/record.json")
            rid = status.get("h1_report_id")
            url = status.get("h1_url")
            if rid:
                print(f"h1_report_id: {rid}")
            if url:
                print(f"h1_url: {url}")
            # B9: if record.json exists but has no valid schema/id, warn.
            # B6/R2: use `not rid` (covers both None and "") — status_report
            # returns "" (not None) for empty report_id/url.
            if not rid and not url:
                print("record_warning: record.json is corrupt or has an unrecognized schema")
        else:
            print("record: none")
    else:
        print("package: none")
    # Legacy submission (Task 1 backward-compat path).
    if status["submission_exists"]:
        print(f"submission: {status['submission_path']}")
    else:
        print("submission: none")

    try:
        engagement_name = str(md.get("engagement", "") or "")
    except Exception:  # pragma: no cover — defensive
        engagement_name = ""
    _audit_h1(
        AUDIT_ACTION_STATUS, status.get("report_path", ""), engagement_name, 0,
        int((time.monotonic() - start_time) * 1000), ws,
        detail=(
            f"package={'yes' if latest else 'no'} "
            f"integrity={'ok' if status.get('integrity_ok') else 'drift'} "
            f"record={'yes' if status.get('record_exists') else 'no'}"
        ),
    )
    return 0


def cmd_prepare(args: list[str]) -> int:
    """Prepare an immutable submission package. Exit 0 on success, 2 on
    validation failure, 1 on fs/parse/internal errors."""
    workspace: str | None = None
    skip_review = False
    i = 0
    while i < len(args):
        a = args[i]
        if a == "--skip-review":
            skip_review = True
            i += 1
            continue
        if a.startswith("-"):
            print(f"unknown flag: {a}", file=sys.stderr)
            return 1
        if workspace is not None:
            print(f"prepare takes at most one workspace argument; got: {args}", file=sys.stderr)
            return 1
        workspace = a
        i += 1

    lab_root = _resolve_lab_root()
    start_time = time.monotonic()

    try:
        result = h1report.prepare_report(workspace, lab_root=lab_root, skip_review=skip_review)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_PREPARE, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="report file not found",
        )
        return 1
    except h1report.ReportParseError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_PREPARE, "", "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="report parse error",
        )
        return 1
    except h1report.ReportValidationError as e:
        # Print the issues and exit 2 (validation failure).
        for issue in e.issues:
            _print_issue(issue)
        errors, warns, _infos = _summarize(e.issues)
        print("FAIL")
        _audit_h1(
            AUDIT_ACTION_PREPARE, str(workspace or ""), "", 2,
            int((time.monotonic() - start_time) * 1000), None,
            detail=f"validation failed errors={errors} warns={warns}",
        )
        return 2
    except h1report.PackageExistsError as e:
        # Immutable: never overwrite. Treat as validation failure (exit 2).
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_PREPARE, str(workspace or ""), "", 2,
            int((time.monotonic() - start_time) * 1000), None,
            detail="package already exists",
        )
        return 2
    except h1report.PackageError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_PREPARE, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="filesystem error during prepare",
        )
        return 1

    pkg_id = result.get("package_id", "")
    copied = result.get("attachments_copied", 0)
    snaps = result.get("scope_snapshots", 0)
    review_verdict = result.get("review_verdict", "")
    print(
        f"SUMMARY: prepared=1 attachments={copied} scope_snapshots={snaps} "
        f"review={review_verdict} package={pkg_id}"
    )
    print(f"PACKAGE: {result.get('package_path', '')}")
    if review_verdict == "warn":
        print(
            "REVIEW WARN: the semantic review surfaced warnings — review them "
            "before submitting (see manifest.json review.dimensions)",
            file=sys.stderr,
        )
    # Resolve the workspace Path for workspace_id attribution (best-effort;
    # prepare_report already resolved it internally, so this only fails if
    # the workspace was removed between the prepare and now — extremely
    # unlikely, and workspace_id is purely attribution metadata).
    ws_path: Path | None = None
    with contextlib.suppress(Exception):
        ws_path = h1report.resolve_workspace(workspace)
    _audit_h1(
        AUDIT_ACTION_PREPARE, str(workspace or ""), "", 0,
        int((time.monotonic() - start_time) * 1000), ws_path,
        detail=f"prepared=1 attachments={copied} package={pkg_id}",
    )
    return 0


def _parse_record_args(args: list[str]) -> tuple[str | None, dict[str, str], int]:
    """Parse record-submission args. Returns (workspace, flags, exit_code).
    exit_code is 0 on success, 1 on usage error. Supports both --flag value
    and --flag=value syntax (B2, for consistency with lab-scope/lab-new)."""
    workspace: str | None = None
    flags: dict[str, str] = {}
    i = 0
    # The first positional (if any) is the workspace. Flags are --key value or --key=value.
    required = ("--package", "--h1-id", "--url", "--submitted-at")
    optional = ("--submitted-by",)
    all_flags = required + optional
    while i < len(args):
        a = args[i]
        # B2: handle --flag=value syntax by splitting on the first '='.
        if a.startswith("--") and "=" in a:
            name, _, value = a.partition("=")
            if name in all_flags:
                flags[name] = value
                i += 1
                continue
            print(f"unknown flag: {a}", file=sys.stderr)
            return None, {}, 1
        if a in all_flags:
            if i + 1 >= len(args):
                print(f"flag {a} requires a value", file=sys.stderr)
                return None, {}, 1
            flags[a] = args[i + 1]
            i += 2
            continue
        if a.startswith("-"):
            print(f"unknown flag: {a}", file=sys.stderr)
            return None, {}, 1
        # Positional -> workspace (only one allowed).
        if workspace is not None:
            print(
                f"record-submission takes at most one workspace argument; got: {args}",
                file=sys.stderr,
            )
            return None, {}, 1
        workspace = a
        i += 1
    # All required flags present?
    for r in required:
        if r not in flags:
            print(f"record-submission requires {r}", file=sys.stderr)
            return None, {}, 1
    return workspace, flags, 0


def cmd_record_submission(args: list[str]) -> int:
    """Record a human-submitted HackerOne report. Exit 0 on success, 2 on
    validation failure, 1 on fs/parse/internal errors."""
    workspace, flags, parse_rc = _parse_record_args(args)
    if parse_rc != 0:
        return parse_rc

    lab_root = _resolve_lab_root()
    start_time = time.monotonic()

    try:
        result = h1report.record_submission(
            workspace,
            lab_root=lab_root,
            package=flags["--package"],
            h1_id=flags["--h1-id"],
            url=flags["--url"],
            submitted_at=flags["--submitted-at"],
            submitted_by=flags.get("--submitted-by", ""),
        )
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="workspace not found",
        )
        return 1
    except h1report.PackageError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="package filesystem error",
        )
        return 1
    except h1report.RecordValidationError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD, str(workspace or ""), "", 2,
            int((time.monotonic() - start_time) * 1000), None,
            detail="validation failed",
        )
        return 2
    except h1report.RecordExistsError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD, str(workspace or ""), "", 2,
            int((time.monotonic() - start_time) * 1000), None,
            detail="record already exists",
        )
        return 2

    rid = result.get("report_id", "")
    print(f"RECORDED: {result.get('record_path', '')}")
    print(f"REPORT_ID: {rid}")
    # Resolve the workspace Path for workspace_id attribution (best-effort;
    # record_submission may have succeeded even if resolve_workspace now
    # fails, so wrap it).
    ws_path: Path | None = None
    with contextlib.suppress(Exception):
        ws_path = h1report.resolve_workspace(workspace)
    _audit_h1(
        AUDIT_ACTION_RECORD, str(workspace or ""), "", 0,
        int((time.monotonic() - start_time) * 1000), ws_path,
        detail=f"recorded report_id={rid}",
    )
    return 0


# ─── record-outcome ────────────────────────────────────────────────────────────


def _parse_record_outcome_args(args: list[str]) -> tuple[str | None, dict[str, str], int]:
    """Parse record-outcome args. Returns (workspace, flags, exit_code).

    exit_code is 0 on success, 1 on usage error. Supports both --flag value
    and --flag=value syntax (same convention as record-submission).
    """
    workspace: str | None = None
    flags: dict[str, str] = {}
    i = 0
    required = ("--h1-id", "--state")
    optional = (
        "--duplicate-of",
        "--duplicate-original-state",
        "--final-severity",
        "--bounty-amount",
        "--bounty-currency",
        "--notes",
        "--source",
    )
    all_flags = required + optional
    while i < len(args):
        a = args[i]
        # --flag=value syntax.
        if a.startswith("--") and "=" in a:
            name, _, value = a.partition("=")
            if name in all_flags:
                flags[name] = value
                i += 1
                continue
            print(f"unknown flag: {a}", file=sys.stderr)
            return None, {}, 1
        if a in all_flags:
            if i + 1 >= len(args):
                print(f"flag {a} requires a value", file=sys.stderr)
                return None, {}, 1
            flags[a] = args[i + 1]
            i += 2
            continue
        if a.startswith("-"):
            print(f"unknown flag: {a}", file=sys.stderr)
            return None, {}, 1
        # Positional -> workspace (only one allowed).
        if workspace is not None:
            print(
                f"record-outcome takes at most one workspace argument; got: {args}",
                file=sys.stderr,
            )
            return None, {}, 1
        workspace = a
        i += 1
    # All required flags present?
    for r in required:
        if r not in flags:
            print(f"record-outcome requires {r}", file=sys.stderr)
            return None, {}, 1
    return workspace, flags, 0


def _resolve_workspace_engagement(
    workspace: str | None, lab_root: Path
) -> tuple[Path, str, int]:
    """Resolve (workspace_path, engagement_name, exit_code).

    exit_code is 0 on success, 1 on resolution failure. The engagement name
    is read from <workspace>/engagement.txt (mirrors h1report.read_engagement_name
    — rejects symlinked engagement.txt). The workspace is resolved via
    h1report.resolve_workspace.
    """
    try:
        ws = h1report.resolve_workspace(workspace)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return Path(), "", 1
    # Read the engagement name from the workspace (engagement.txt).
    eng_name = finding_events.read_engagement_name_from_workspace(ws)
    if not eng_name:
        # Fall back to the report frontmatter's engagement field, if present.
        with contextlib.suppress(Exception):
            report_path = h1report.find_report_file(ws)
            report = h1report.parse_report(report_path)
            eng_name = str(report.frontmatter.get("engagement", "") or "")
    if not eng_name:
        print(
            "ERROR: could not determine engagement for workspace "
            "(no engagement.txt and no frontmatter engagement field)",
            file=sys.stderr,
        )
        return Path(), "", 1
    return ws, eng_name, 0


def cmd_record_outcome(args: list[str]) -> int:
    """Record a platform outcome event for a finding. Exit 0 on success,
    2 on validation failure (invalid state, no submission found, duplicate
    without --duplicate-of), 1 on fs/parse/internal errors.

    Per roadmap section 7.3 + ADR-0002:
      1. Resolve the workspace's latest submission package (best-effort —
         we don't hard-require a record.json, since an outcome can be
         recorded before the submission receipt is filed).
      2. Validate --state against the supported enum (finding_events).
      3. If --state duplicate, require --duplicate-of.
      4. Append the outcome event to <engagement>/.lab/outcomes.jsonl
         (engagement-private, gitignored — NOT the workspace).
      5. Emit an audit event.
      6. Print the outcome_id.
      7. Never modify the immutable record.json.
    """
    workspace, flags, parse_rc = _parse_record_outcome_args(args)
    if parse_rc != 0:
        return parse_rc

    lab_root = _resolve_lab_root()
    start_time = time.monotonic()

    # Resolve workspace + engagement.
    ws, eng_name, resolve_rc = _resolve_workspace_engagement(workspace, lab_root)
    if resolve_rc != 0:
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(workspace or ""), "", 1,
            int((time.monotonic() - start_time) * 1000), None,
            detail="workspace/engagement resolution failed",
        )
        return 1

    # Validate --state.
    state = flags["--state"]
    if state not in finding_events.OUTCOME_STATES:
        print(
            f"ERROR: invalid state {state!r}. Must be one of: "
            f"{', '.join(sorted(finding_events.OUTCOME_STATES))}",
            file=sys.stderr,
        )
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 2,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"invalid state={state}",
        )
        return 2

    # If state=duplicate, require --duplicate-of.
    duplicate_of = flags.get("--duplicate-of") or None
    if state == "duplicate" and not duplicate_of:
        print(
            "ERROR: --state duplicate requires --duplicate-of <original-report-id>",
            file=sys.stderr,
        )
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 2,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="duplicate state without --duplicate-of",
        )
        return 2

    # Validate --duplicate-original-state, if provided.
    duplicate_original_state = flags.get("--duplicate-original-state") or None
    if (
        duplicate_original_state is not None
        and duplicate_original_state not in finding_events.OUTCOME_STATES
    ):
        print(
            f"ERROR: invalid --duplicate-original-state {duplicate_original_state!r}. "
            f"Must be one of: {', '.join(sorted(finding_events.OUTCOME_STATES))}",
            file=sys.stderr,
        )
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 2,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"invalid duplicate_original_state={duplicate_original_state}",
        )
        return 2

    # Validate --final-severity, if provided.
    final_severity = flags.get("--final-severity") or None
    if (
        final_severity is not None
        and final_severity not in ("low", "medium", "high", "critical")
    ):
        print(
            f"ERROR: invalid --final-severity {final_severity!r}. "
            "Must be one of: low, medium, high, critical",
            file=sys.stderr,
        )
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 2,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"invalid final_severity={final_severity}",
        )
        return 2

    # Validate --source, if provided.
    source = flags.get("--source") or "human_h1_import"
    if source not in ("human_h1_import", "auto_h1_api", "manual"):
        print(
            f"ERROR: invalid --source {source!r}. "
            "Must be one of: human_h1_import, auto_h1_api, manual",
            file=sys.stderr,
        )
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 2,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"invalid source={source}",
        )
        return 2

    # Validate --bounty-amount, if provided (must parse as a number).
    bounty_amount: float | None = None
    bounty_amount_raw = flags.get("--bounty-amount")
    if bounty_amount_raw:
        try:
            bounty_amount = float(bounty_amount_raw)
            if bounty_amount < 0:
                raise ValueError("negative")
        except ValueError:
            print(
                f"ERROR: invalid --bounty-amount {bounty_amount_raw!r}. "
                "Must be a non-negative number.",
                file=sys.stderr,
            )
            _audit_h1(
                AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 2,
                int((time.monotonic() - start_time) * 1000), ws,
                detail=f"invalid bounty_amount={bounty_amount_raw}",
            )
            return 2
    bounty_currency = flags.get("--bounty-currency") or None

    notes = flags.get("--notes") or ""
    report_id = flags["--h1-id"]

    # Resolve the outcomes store path from the engagement name.
    # The store lives at <lab_root>/bounties/<program>/.lab/outcomes.jsonl
    # (engagement-private, gitignored — NOT in the workspace).
    try:
        outcomes_path = finding_events.resolve_store_path(eng_name, lab_root=lab_root)
    except ValueError as e:
        print(f"ERROR: could not resolve outcomes path: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="outcomes path resolution failed",
        )
        return 1

    # Build the outcome event via the helper (validates the full shape).
    try:
        event = finding_events.make_outcome_event(
            report_id=report_id,
            state=state,
            source=source,
            duplicate_of=duplicate_of,
            duplicate_original_state=duplicate_original_state,
            final_severity=final_severity,
            bounty_amount=bounty_amount,
            bounty_currency=bounty_currency,
            notes=notes,
        )
    except finding_events.OutcomeValidationError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 2,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="event validation failed",
        )
        return 2

    # Append to the store. OutcomeStore.append handles locking, symlink
    # rejection, idempotency, and duplicate-event detection.
    store = finding_events.OutcomeStore(outcomes_path)
    try:
        outcome_id = store.append(event)
    except finding_events.OutcomeSymlinkError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="outcomes path is a symlink (refused)",
        )
        return 1
    except finding_events.OutcomeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 1,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="outcome store error",
        )
        return 1

    # Derive the post-record status for the human (read-only).
    try:
        status = store.derive_finding_status(report_id, workspace_path=ws)
    except Exception as e:  # noqa: BLE001 — defensive; status is best-effort
        print(f"RECORDED: outcome_id={outcome_id} (status derivation failed: {e})")
        _audit_h1(
            AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 0,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"recorded state={state} outcome_id={outcome_id}",
        )
        return 0

    print(f"RECORDED: outcome_id={outcome_id}")
    print(f"STATE: {state}")
    if duplicate_of:
        print(f"DUPLICATE_OF: {duplicate_of}")
    print(f"OUTCOMES_PATH: {outcomes_path}")
    print("DERIVED_STATUS:")
    print(f"  submission_state: {status.get('submission_state')}")
    print(f"  platform_state: {status.get('platform_state')}")
    print(f"  reportability: {status.get('reportability')}")
    print(f"  last_event_ts: {status.get('last_event_ts')}")

    _audit_h1(
        AUDIT_ACTION_RECORD_OUTCOME, str(ws), eng_name, 0,
        int((time.monotonic() - start_time) * 1000), ws,
        detail=f"recorded state={state} outcome_id={outcome_id}",
    )
    return 0


# ─── assess (SI-015) ───────────────────────────────────────────────────────────


def _load_submission_thresholds(lab_root: Path) -> dict:
    """Load submission decision thresholds from improvement/config/submission.yaml.

    Returns a dict with keys:
      trial_report_threshold, normal_threshold,
      require_impact_demonstrated, require_novelty_check.

    Falls back to conservative defaults (trial=0.85, normal=0.70,
    require_impact_demonstrated=true, require_novelty_check=true) when the
    file is missing or unparseable. The defaults match the tracked
    improvement/config/submission.yaml so behavior is stable even if the
    file is temporarily absent.
    """
    defaults = {
        "trial_report_threshold": 0.85,
        "normal_threshold": 0.70,
        "require_impact_demonstrated": True,
        "require_novelty_check": True,
    }
    path = lab_root / "improvement" / "config" / "submission.yaml"
    if not path.is_file() or path.is_symlink():
        return defaults
    try:
        import yaml  # type: ignore[import-not-found]
        data = yaml.safe_load(path.read_text(encoding="utf-8"))
    except ImportError:
        # PyYAML not installed — fall back to conservative defaults.
        return defaults
    except (OSError, ValueError, yaml.YAMLError):
        # Unreadable / unparseable submission.yaml — fall back to defaults.
        return defaults
    if not isinstance(data, dict):
        return defaults
    sub = data.get("submission")
    if not isinstance(sub, dict):
        return defaults
    out = dict(defaults)
    for k in defaults:
        v = sub.get(k)
        if v is not None:
            out[k] = v
    return out


def _derive_finding_behavior(workspace: Path) -> str:
    """Derive a behavior string for the finding in `workspace`.

    For MVP (SI-015), the behavior is derived from the report_h1.md title
    (preferred) or the workspace directory name (fallback). This is matched
    by substring against the `behavior` field of each precedent entry in
    the engagement's precedents.yaml.

    Returns "" when no behavior can be derived (e.g. no report_h1.md and
    no resolvable workspace name). The assess command treats "" as "no
    match" — it skips the precedent check rather than BLOCKing.
    """
    # Prefer the report title.
    with contextlib.suppress(Exception):
        report_path = h1report.find_report_file(workspace)
        report = h1report.parse_report(report_path)
        title = str(report.frontmatter.get("title", "") or "").strip()
        if title:
            return title
    # Fall back to the workspace directory name.
    return workspace.name


def _match_precedent(
    behavior: str, precedents: list[dict]
) -> tuple[dict | None, str | None]:
    """Find the first precedent that matches the finding's `behavior`.

    Matching strategy (MVP — per SI-015 task spec, "derive the behavior
    from the finding's report_h1.md title or workspace name. If no match,
    skip the precedent check"):
      1. Substring match in either direction (case-insensitive). Catches
         exact rewordings like "endpointA metadata leak" vs
         "...metadata leak via endpointA...".
      2. Token overlap: if the precedent's behavior and the finding's
         behavior share enough distinctive tokens (>= 2 distinctive
         alphanumeric tokens, ignoring common words like "the", "via",
         "in", "leak", "unauthenticated"), it's a match. This catches
         "endpointA metadata leak" vs "Unauthenticated workspace
         metadata leak via endpointA endpoint" (shared tokens:
         getpublicpagedata, metadata — 2 distinctive tokens).

    SI-031 cross-program promotion (audit §10.3): a precedent is a hard
    BLOCK only when `confirmed_by_programs` lists 2+ independent
    programs. A single-program precedent is advisory: it surfaces a HOLD
    (candidate_informative semantics) with a provenance label so the
    agent knows which program triaged it as Informative. This prevents
    overfitting to one program's triager preferences (audit §10.2).

    Returns (matched_precedent_or_None, block_reason_or_None). When a
    match is found and the precedent's state is `informative` or
    `duplicate` AND `confirmed_by_programs` has 2+ entries, the
    block_reason is set (hard BLOCK). When the match is single-program,
    block_reason is None (the assess command treats it as a HOLD — the
    program has not been cross-validated, so it's advisory). When the
    match is `candidate_informative`, block_reason is None (soft signal).
    """
    if not behavior:
        return None, None
    needle = behavior.lower()
    # Common words to ignore when counting distinctive token overlap.
    # These are generic security-report words that appear in many
    # behaviors and would cause false matches if counted.
    _STOP = {
        "the", "a", "an", "via", "in", "of", "on", "to", "for", "and",
        "or", "with", "without", "by", "leak", "unauthenticated",
        "endpoint", "page", "workspace", "client", "side", "error",
        "reporting", "disclosure", "information", "vulnerability",
        "bypass", "issue", "bug", "report", "token",
    }

    def _distinctive_tokens(s: str) -> set[str]:
        return {
            t for t in _tokenize(s)
            if t not in _STOP and len(t) >= 3
        }

    def _confirmed_programs(p: dict) -> list[str]:
        """Return the confirmed_by_programs list (audit §10.3).
        Falls back to [] when the field is absent (single-program =
        advisory, not blocking)."""
        cbp = p.get("confirmed_by_programs")
        if isinstance(cbp, list):
            return [str(x) for x in cbp if isinstance(x, (str, int))]
        return []

    needle_tokens = _distinctive_tokens(needle)
    for p in precedents:
        pbehavior = str(p.get("behavior", "") or "").strip()
        if not pbehavior:
            continue
        pb = pbehavior.lower()
        matched = False
        # 1. Substring match in either direction.
        if pb in needle or needle in pb:
            matched = True
        # 2. Distinctive token overlap (>= 2 shared distinctive tokens).
        if not matched:
            pb_tokens = _distinctive_tokens(pb)
            if pb_tokens and needle_tokens:
                overlap = pb_tokens & needle_tokens
                if len(overlap) >= 2:
                    matched = True
        if not matched:
            continue
        state = str(p.get("state", "") or "").strip().lower()
        # SI-031: hard BLOCK only when cross-confirmed by 2+ programs.
        # A single-program precedent is advisory (HOLD, not BLOCK) so
        # one program's triager preferences don't block all programs
        # (audit §10.2 overfitting risk).
        confirmed = _confirmed_programs(p)
        if state in ("informative", "duplicate") and len(confirmed) >= 2:
            return p, f"Known {state} behavior (cross-confirmed by {len(confirmed)} programs)"
        # candidate_informative OR single-program informative/duplicate:
        # advisory HOLD, not a hard BLOCK. Return the precedent with no
        # block_reason so the assess command treats it as a soft signal.
        return p, None
    return None, None


def _tokenize(s: str) -> list[str]:
    """Split a string into lowercase alphanumeric tokens."""
    tokens = []
    cur = []
    for ch in s:
        if ch.isalnum():
            cur.append(ch.lower())
        else:
            if cur:
                tokens.append("".join(cur))
                cur = []
    if cur:
        tokens.append("".join(cur))
    return tokens


def cmd_assess(args: list[str]) -> int:
    """Assess whether a finding should be submitted to HackerOne.

    Per roadmap section 12.1-12.2 (SI-015). This is a recommendation,
    not a guarantee — the human makes the final call. The command is
    read-only and local-only: no network, no subprocess, no mutation of
    any file.

    Exit codes:
      0 = PASS   — evidence and novelty sufficient, submission recommended
      1 = BLOCK  — known duplicate, Informative precedent, or technical
                   verdict not confirmed
      2 = HOLD   — more evidence required (impact not demonstrated or
                   confidence below threshold)
      3 = ERROR  — filesystem/parse error (workspace not found, report
                   unparseable, precedents.yaml corrupt, etc.)

    Behavior (per roadmap section 12.2 assess_submission()):
      1. Resolve workspace + engagement + report_id (from record.json or
         frontmatter).
      2. Call finding_events.derive_finding_status() for the authoritative
         platform_state, technical_verdict, impact_demonstrated, confidence.
      3. Load the engagement's precedents via load_precedents().
      4. BLOCK conditions (hard stops):
         - platform_state == "duplicate"        -> "Already submitted, closed as duplicate"
         - platform_state == "informative"      -> "Previously closed as Informative"
         - behavior matches a known Informative precedent
                                                  -> "Known Informative behavior for this program"
         - technical_verdict != "confirmed"     -> "Technical verdict is not 'confirmed'"
      5. HOLD conditions:
         - impact_demonstrated == false -> "Impact not demonstrated"
         - confidence < trial_report_threshold
                                            -> "Confidence below threshold"
      6. Otherwise -> PASS ("Evidence and novelty sufficient for submission").
    """
    workspace: str | None = None
    if len(args) > 1:
        print(f"assess takes at most one optional workspace argument; got: {args}", file=sys.stderr)
        return ASSESS_EXIT_ERROR
    if len(args) == 1:
        workspace = args[0]

    lab_root = _resolve_lab_root()
    start_time = time.monotonic()

    # Resolve workspace (filesystem errors -> exit 3).
    try:
        ws = h1report.resolve_workspace(workspace)
    except h1report.ReportFileError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(workspace or ""), "", ASSESS_EXIT_ERROR,
            int((time.monotonic() - start_time) * 1000), None,
            detail="workspace not found",
        )
        return ASSESS_EXIT_ERROR

    # Read the engagement name from the workspace (engagement.txt),
    # falling back to the report frontmatter. Without an engagement name
    # we can't resolve the outcomes store or precedents — exit 3.
    eng_name = finding_events.read_engagement_name_from_workspace(ws)
    report_path = None
    report = None
    if not eng_name:
        with contextlib.suppress(Exception):
            report_path = h1report.find_report_file(ws)
            report = h1report.parse_report(report_path)
            eng_name = str(report.frontmatter.get("engagement", "") or "")
    if not eng_name:
        print(
            "ERROR: could not determine engagement for workspace "
            "(no engagement.txt and no frontmatter engagement field)",
            file=sys.stderr,
        )
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), "", ASSESS_EXIT_ERROR,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="engagement resolution failed",
        )
        return ASSESS_EXIT_ERROR

    # Resolve the report_id from the latest record.json, falling back to
    # the report frontmatter. The assess command needs a report_id to
    # look up the finding's platform outcome. When no report_id is
    # resolvable (no record.json, no frontmatter id), we use "" — the
    # derive_finding_status() call will return platform_state=None, which
    # falls through to the HOLD/BLOCK-on-technical-verdict checks.
    report_id = ""
    # Try the latest record.json first.
    submission = ws / "submission"
    if submission.is_dir():
        pat = __import__("re").compile(r"^prepared-\d{8}T\d{6}Z$")
        candidates: list[tuple[str, Path]] = []
        try:
            for entry in submission.iterdir():
                if entry.is_symlink() or not entry.is_dir():
                    continue
                if pat.match(entry.name):
                    candidates.append((entry.name, entry))
        except OSError:
            pass
        if candidates:
            candidates.sort(key=lambda t: t[0])
            _, latest_pkg = candidates[-1]
            rpath = latest_pkg / "record.json"
            if rpath.is_file() and not rpath.is_symlink():
                try:
                    import json
                    rec = json.loads(rpath.read_text(encoding="utf-8"))
                    if isinstance(rec, dict):
                        rid = rec.get("report_id")
                        if isinstance(rid, (str, int)) and str(rid):
                            report_id = str(rid)
                except (OSError, ValueError):
                    pass  # corrupt record.json — fall through

    # If no report_id from record.json, try the report frontmatter (some
    # engagements record the intended/assigned ID there after submission).
    if not report_id and report is not None:
        with contextlib.suppress(Exception):
            rid = report.frontmatter.get("h1_report_id") or report.frontmatter.get("report_id")
            if isinstance(rid, (str, int)) and str(rid):
                report_id = str(rid)

    # Load submission thresholds.
    thresholds = _load_submission_thresholds(lab_root)
    trial_threshold = float(thresholds.get("trial_report_threshold", 0.85) or 0.85)

    # Derive the authoritative finding status. This is read-only.
    try:
        status = finding_events.derive_finding_status(
            report_id, workspace_path=ws, engagement_name=eng_name, lab_root=lab_root
        )
    except finding_events.OutcomeError as e:
        print(f"ERROR: could not derive finding status: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_ERROR,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="status derivation failed",
        )
        return ASSESS_EXIT_ERROR

    # Load precedents (private, gitignored). Missing file = no precedents
    # (don't error — a new engagement has no precedents yet).
    eng_path = finding_events.resolve_engagement_path(eng_name, lab_root=lab_root)
    try:
        precedents = finding_events.load_precedents(eng_path)
    except finding_events.OutcomeSymlinkError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_ERROR,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="precedents.yaml is a symlink (refused)",
        )
        return ASSESS_EXIT_ERROR
    except finding_events.OutcomeParseError as e:
        print(f"ERROR: precedents.yaml parse error: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_ERROR,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="precedents.yaml parse error",
        )
        return ASSESS_EXIT_ERROR
    except finding_events.OutcomeError as e:
        print(f"ERROR: could not load precedents: {e}", file=sys.stderr)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_ERROR,
            int((time.monotonic() - start_time) * 1000), ws,
            detail="precedents load failed",
        )
        return ASSESS_EXIT_ERROR

    # Derive the finding's behavior for precedent matching.
    behavior = _derive_finding_behavior(ws)

    # ─── BLOCK conditions (hard stops) ──────────────────────────────────
    platform_state = status.get("platform_state")
    technical_verdict = status.get("technical_verdict")
    duplicate_of = status.get("duplicate_of")

    if platform_state == "duplicate":
        reason = "Already submitted, closed as duplicate"
        if duplicate_of:
            reason += f" (of {duplicate_of})"
        _print_assess_result("BLOCK", reason, status, report_id, behavior, eng_name)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_BLOCK,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"BLOCK platform_state=duplicate report_id={report_id}",
        )
        return ASSESS_EXIT_BLOCK

    if platform_state == "informative":
        reason = "Previously closed as Informative"
        _print_assess_result("BLOCK", reason, status, report_id, behavior, eng_name)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_BLOCK,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"BLOCK platform_state=informative report_id={report_id}",
        )
        return ASSESS_EXIT_BLOCK

    # Precedent match (behavior against known Informative/Duplicate).
    matched, precedent_reason = _match_precedent(behavior, precedents)
    if matched is not None and precedent_reason is not None:
        _print_assess_result(
            "BLOCK", precedent_reason, status, report_id, behavior, eng_name,
            precedent=matched,
        )
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_BLOCK,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"BLOCK precedent_match report_id={report_id}",
        )
        return ASSESS_EXIT_BLOCK

    if technical_verdict != "confirmed":
        reason = f"Technical verdict is not 'confirmed' (got {technical_verdict!r})"
        _print_assess_result("BLOCK", reason, status, report_id, behavior, eng_name)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_BLOCK,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"BLOCK technical_verdict={technical_verdict} report_id={report_id}",
        )
        return ASSESS_EXIT_BLOCK

    # ─── HOLD conditions (need more work) ───────────────────────────────
    impact_demonstrated = bool(status.get("impact_demonstrated"))
    confidence = float(status.get("confidence") or 0.0)

    if not impact_demonstrated:
        reason = "Impact not demonstrated — response is empty or theoretical"
        _print_assess_result("HOLD", reason, status, report_id, behavior, eng_name)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_HOLD,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"HOLD impact_not_demonstrated report_id={report_id}",
        )
        return ASSESS_EXIT_HOLD

    if confidence < trial_threshold:
        reason = f"Confidence {confidence} below trial threshold {trial_threshold}"
        _print_assess_result("HOLD", reason, status, report_id, behavior, eng_name)
        _audit_h1(
            AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_HOLD,
            int((time.monotonic() - start_time) * 1000), ws,
            detail=f"HOLD confidence={confidence}<{trial_threshold} report_id={report_id}",
        )
        return ASSESS_EXIT_HOLD

    # candidate_informative OR single-program precedent match (soft
    # signal) — HOLD, not BLOCK. SI-031 (audit §10.3): a single-program
    # precedent is advisory (provenance-labelled) because one program's
    # triager preferences should not block all programs (overfitting
    # risk). Only 2+-program-confirmed precedents hard-BLOCK (handled
    # above via precedent_reason).
    if matched is not None:
        state = str(matched.get("state", "") or "").strip().lower()
        confirmed = matched.get("confirmed_by_programs")
        confirmed_count = (
            len([str(x) for x in confirmed if isinstance(x, (str, int))])
            if isinstance(confirmed, list) else 0
        )
        if state == "candidate_informative":
            reason = (
                "Behavior matches a candidate_informative precedent — "
                "confirm program stance before submitting"
            )
            _print_assess_result(
                "HOLD", reason, status, report_id, behavior, eng_name,
                precedent=matched,
            )
            _audit_h1(
                AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_HOLD,
                int((time.monotonic() - start_time) * 1000), ws,
                detail=f"HOLD candidate_informative_precedent report_id={report_id}",
            )
            return ASSESS_EXIT_HOLD
        if state in ("informative", "duplicate") and confirmed_count < 2:
            reason = (
                f"Behavior matches a single-program {state} precedent "
                f"(program={matched.get('program', '?')!r}, "
                f"confirmed_by_programs={confirmed_count}) — advisory "
                f"only; cross-program confirmation (2+ programs) is "
                f"required before this becomes a hard BLOCK. Confirm "
                f"this program's stance before submitting."
            )
            _print_assess_result(
                "HOLD", reason, status, report_id, behavior, eng_name,
                precedent=matched,
            )
            _audit_h1(
                AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_HOLD,
                int((time.monotonic() - start_time) * 1000), ws,
                detail=f"HOLD single_program_precedent state={state} confirmed={confirmed_count} report_id={report_id}",
            )
            return ASSESS_EXIT_HOLD

    # ─── PASS ───────────────────────────────────────────────────────────
    reason = "Evidence and novelty sufficient for submission"
    _print_assess_result("PASS", reason, status, report_id, behavior, eng_name)
    _audit_h1(
        AUDIT_ACTION_ASSESS, str(ws), eng_name, ASSESS_EXIT_PASS,
        int((time.monotonic() - start_time) * 1000), ws,
        detail=f"PASS report_id={report_id}",
    )
    return ASSESS_EXIT_PASS


def _print_assess_result(
    verdict: str,
    reason: str,
    status: dict,
    report_id: str,
    behavior: str,
    engagement: str,
    *,
    precedent: dict | None = None,
) -> None:
    """Print the assess result block (ASCII only — no secrets)."""
    print(f"ASSESS: {verdict}")
    print(f"REASON: {reason}")
    print(f"ENGAGEMENT: {engagement}")
    print(f"REPORT_ID: {report_id or '(none)'}")
    print(f"BEHAVIOR: {behavior or '(none)'}")
    print("STATUS:")
    print(f"  platform_state: {status.get('platform_state')}")
    print(f"  technical_verdict: {status.get('technical_verdict')}")
    print(f"  impact_demonstrated: {status.get('impact_demonstrated')}")
    print(f"  confidence: {status.get('confidence')}")
    print(f"  reportability: {status.get('reportability')}")
    if precedent is not None:
        print("PRECEDENT:")
        print(f"  behavior: {precedent.get('behavior', '')}")
        print(f"  state: {precedent.get('state', '')}")
        rid = precedent.get("report_id")
        print(f"  report_id: {rid if rid else '(none)'}")


def main(argv: list[str] | None = None) -> int:
    args = list(argv) if argv is not None else sys.argv[1:]
    if not args:
        usage()
        return 1
    cmd = args[0]
    rest = args[1:]
    if cmd in ("-h", "--help"):
        usage()
        return 0
    if cmd == "check":
        return cmd_check(rest)
    if cmd == "review":
        return cmd_review(rest)
    if cmd == "prepare":
        return cmd_prepare(rest)
    if cmd == "status":
        return cmd_status(rest)
    if cmd == "record-submission":
        return cmd_record_submission(rest)
    if cmd == "record-outcome":
        return cmd_record_outcome(rest)
    if cmd == "assess":
        return cmd_assess(rest)
    # No submit command exists and never will. Unknown commands fail.
    if cmd == "submit":
        print("ERROR: 'submit' is not a command. Final submission is a human action.", file=sys.stderr)
        return 1
    print(f"Unknown command: {cmd}", file=sys.stderr)
    usage()
    return 1


if __name__ == "__main__":
    raise SystemExit(main())

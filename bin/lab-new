#!/usr/bin/env python3
"""lab-new — generalized workspace creator for the multi-engagement hacking lab.

Creates a scoped, evidence-ready workspace for any engagement type:
    ctf, bounty, or cve.

Usage:
    lab-new <type> <name> [--target <url>] [--engagement <name>] [--category <web|crypto|...>]

Examples:
    lab-new ctf my-challenge --target http://localhost:8080 --engagement ctf-example
    lab-new bounty my-program --target example.com --engagement bounty-example
    lab-new cve log4j --engagement cve-research

Creates:
    ~/security-lab/findings/<type>/<name>/
        ├── engagement.txt            # engagement name (for downstream tools)
        ├── target.txt                 # target URL or host
        ├── scope_snapshot.yaml        # copy of the engagement scope file
        ├── solve_log.md OR bounty_log.md OR cve_log.md
        ├── writeup.md OR report_h1.md OR advisory.md
        ├── work/exploit.py OR poc.py
        ├── work/endpoint_siblings.txt
        ├── evidence/
        ├── recon/
        └── web-attack/

The workspace is self-contained: each has its own scope snapshot, log,
evidence, and work dirs. Multiple agents can work in parallel without
cross-contamination.
"""

from __future__ import annotations

import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

# Import shared labutil helpers
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))
import labutil  # noqa: E402

LAB = labutil.LAB
FINDINGS_ROOT = LAB / "findings"
ENGAGEMENTS_DIR = LAB / "engagements"
TEMPLATES_DIR = LAB / "templates"
GLOBAL_SCOPE = LAB / "scope.yaml"

TYPE_CONFIG = {
    "ctf": {
        "findings_subdir": "ctf",
        "workspace_subdir": "challenges",
        "log_template": "solve_log.md",
        "log_filename": "solve_log.md",
        "writeup_filename": "writeup.md",
        "exploit_filename": "exploit.py",
        "exploit_template": "exploit.py",
        "template_subdir": "ctf",
        "default_engagement": "",
        "default_category": "web",
    },
    "bounty": {
        "findings_subdir": "bounty",
        "workspace_subdir": "findings",
        "log_template": "bounty_log.md",
        "log_filename": "bounty_log.md",
        "writeup_filename": "report_h1.md",
        "exploit_filename": "exploit.py",
        "exploit_template": "exploit.py",
        "template_subdir": "bounty",
        "default_engagement": "",
        "default_category": "web",
    },
    "cve": {
        "findings_subdir": "cve",
        "workspace_subdir": "findings",
        "log_template": "cve_log.md",
        "log_filename": "cve_log.md",
        "writeup_filename": "advisory.md",
        "exploit_filename": "poc.py",
        "exploit_template": "poc.py",
        "template_subdir": "cve",
        "default_engagement": "cve-research",
        "default_category": "web",
    },
}


def usage() -> None:
    print(__doc__)


def parse_args() -> dict[str, Any]:
    args = {"type": "", "name": "", "target": "", "engagement": "", "category": ""}
    remaining = sys.argv[1:]

    if not remaining or remaining[0] in ("-h", "--help"):
        usage()
        sys.exit(0)

    idx = 0
    while idx < len(remaining):
        arg = remaining[idx]
        if arg in ("--target", "--url") and idx + 1 < len(remaining):
            args["target"] = remaining[idx + 1]
            idx += 2
        elif arg.startswith("--target="):
            args["target"] = arg.split("=", 1)[1]
            idx += 1
        elif arg == "--engagement" and idx + 1 < len(remaining):
            args["engagement"] = remaining[idx + 1]
            idx += 2
        elif arg.startswith("--engagement="):
            args["engagement"] = arg.split("=", 1)[1]
            idx += 1
        elif arg == "--category" and idx + 1 < len(remaining):
            args["category"] = remaining[idx + 1]
            idx += 2
        elif arg.startswith("--category="):
            args["category"] = arg.split("=", 1)[1]
            idx += 1
        elif arg.startswith("-"):
            print(f"Unknown option: {arg}", file=sys.stderr)
            sys.exit(2)
        elif not args["type"]:
            args["type"] = arg
            idx += 1
        elif not args["name"]:
            args["name"] = arg
            idx += 1
        else:
            print(f"Unexpected argument: {arg}", file=sys.stderr)
            sys.exit(2)

    if not args["type"] or not args["name"]:
        usage()
        sys.exit(2)

    if args["type"] not in TYPE_CONFIG:
        print(f"Unknown type: {args['type']}. Must be one of: {', '.join(TYPE_CONFIG)}", file=sys.stderr)
        sys.exit(2)

    name_check = re.match(r"^[A-Za-z0-9._-]+$", args["name"])
    if not name_check:
        print(f"Invalid name: {args['name']}. Use only letters, numbers, dots, hyphens, underscores.", file=sys.stderr)
        sys.exit(2)

    if ".." in args["name"] or "/" in args["name"] or "\\" in args["name"]:
        print(f"Invalid name: {args['name']}", file=sys.stderr)
        sys.exit(2)

    return args


def scope_check(target: str, engagement: str) -> tuple[int, str]:
    # B2/R3: pass "--" before the target so a target value like "--list" is
    # treated as a positional arg, not a flag (argument-injection guard).
    result = subprocess.run(
        [str(LAB / "bin" / "lab-scope"), "--", target, "--engagement", engagement],
        capture_output=True,
        text=True,
    )
    return result.returncode, result.stdout.strip()


def _yaml_scalar_escape(value: str) -> str:
    """Escape a string for safe insertion into a double-quoted YAML scalar.

    P2: report_h1.md frontmatter scalars (engagement, program, program_url,
    title) are now double-quoted in the template, but a value containing a
    literal double-quote would break the YAML. Escape backslashes and
    double-quotes so the quoted scalar stays valid regardless of the
    program/engagement name. Newlines are already rejected upstream for
    --target; for other fields we replace them with spaces (a YAML
    double-quoted scalar cannot contain a raw newline without CRLF escaping).
    """
    if not value:
        return ""
    # Replace newlines with spaces (cannot appear in a single-line quoted scalar).
    v = value.replace("\r", " ").replace("\n", " ")
    # Escape backslashes first, then double-quotes.
    return v.replace("\\", "\\\\").replace('"', '\\"')


def fill_template(template_path: Path, dest_path: Path, replacements: dict[str, str]) -> None:
    """Fill a template by replacing {{KEY}} placeholders with values.

    S7: do a single-pass replacement so a value containing another {{KEY}}
    (e.g. --target='{{PROGRAM_URL}}') is NOT re-interpreted by a later
    replacement key. Uses a regex that substitutes all keys in one pass,
    so replacement values are inserted verbatim and never re-scanned.
    """
    text = template_path.read_text(encoding="utf-8")
    if replacements:
        # Build a single regex matching any {{KEY}} and substitute in one pass.
        # Values are inserted literally (no re-scanning for {{...}}).
        pattern = re.compile(
            r"\{\{(" + "|".join(re.escape(k) for k in replacements) + r")\}\}"
        )
        text = pattern.sub(lambda m: replacements[m.group(1)], text)
    dest_path.write_text(text, encoding="utf-8")


def main() -> int:
    args = parse_args()
    cfg = TYPE_CONFIG[args["type"]]

    # S4/R2: reject newlines in --target to prevent YAML injection into the
    # report_h1.md frontmatter live_targets list (a target like
    # 'https://evil\n  - https://gov.example.com' would inject an extra entry).
    if args["type"] == "bounty" and args["target"]:
        if "\n" in args["target"] or "\r" in args["target"]:
            print(
                "ERROR: --target contains a newline; refusing to inject into "
                "YAML frontmatter (use a single URL)",
                file=sys.stderr,
            )
            return 2

    engagement = args["engagement"] or cfg["default_engagement"]
    if not engagement:
        print(f"ERROR: --engagement is required for type '{args['type']}'", file=sys.stderr)
        return 2

    # S1/R6: validate the engagement name before using it in a path. --name is
    # already validated (lines 148-155), but --engagement was not, allowing
    # path traversal (e.g. '../evil') to read/copy a file outside engagements/.
    if not labutil.validate_name(engagement):
        print(
            f"ERROR: invalid engagement name {engagement!r}. Use only letters, "
            f"numbers, dots, hyphens, underscores. No '..', '/', or '\\'.",
            file=sys.stderr,
        )
        return 2

    eng_scope_path = ENGAGEMENTS_DIR / f"{engagement}.yaml"
    if not eng_scope_path.exists():
        print(f"ERROR: engagement scope file not found: {eng_scope_path}", file=sys.stderr)
        print(f"Available engagements:", file=sys.stderr)
        for f in sorted(ENGAGEMENTS_DIR.glob("*.yaml")):
            print(f"  {f.stem}", file=sys.stderr)
        return 2

    scope_checked = "no"
    if args["target"]:
        code, msg = scope_check(args["target"], engagement)
        print(msg)
        if code == 0:
            scope_checked = "yes"
        elif code == 2:
            return 2
        elif code == 3:
            print("Target not in scope. Add it to the engagement scope file or confirm with human.", file=sys.stderr)
            return 3
        else:
            # S1/R5: fail-closed on any non-0/2/3 exit code (e.g. lab-scope
            # crashed on malformed YAML -> exit 1). The global denied list is
            # the lab's hardest safety rail and must NEVER be silently disabled.
            print(
                f"ERROR: scope check failed (lab-scope exit {code}): {msg}",
                file=sys.stderr,
            )
            return 2
    elif args["type"] in ("ctf", "bounty"):
        # T2-19: warn when no --target on ctf/bounty (scope not checked)
        print("WARNING: no --target provided, scope not checked. Pass --target <url> to enable scope validation.", file=sys.stderr)

    # Determine workspace path: cd-then-create mode or legacy global mode.
    # T2-47: walk up from cwd to find a program folder (has AGENTS.md AND
    # a challenges/ or findings/ subdir), so running lab-new from inside a
    # challenge dir finds the program folder. Don't match the lab root's
    # AGENTS.md (it has no challenges/ or findings/ — it has ctfs/, bounties/).
    cwd = Path.cwd()
    program_root = None
    search = cwd
    while search != search.parent:
        if (search / "AGENTS.md").exists():
            # Only treat as program root if it has the expected workspace
            # subdir (challenges/ for CTF, findings/ for bounty/cve).
            # This prevents the lab root's AGENTS.md from matching.
            if (search / cfg["workspace_subdir"]).is_dir():
                program_root = search
                break
        search = search.parent
    if program_root is not None:
        # cd-then-create: workspace = <program_root>/<workspace_subdir>/<name>/
        work = program_root / cfg["workspace_subdir"] / args["name"]
        ws_mode = "program"
    else:
        # Legacy: workspace = ~/security-lab/findings/<type>/<name>/
        work = FINDINGS_ROOT / cfg["findings_subdir"] / args["name"]
        ws_mode = "legacy"

    work.mkdir(parents=True, exist_ok=True)

    (work / "recon").mkdir(exist_ok=True)
    (work / "web-attack").mkdir(exist_ok=True)
    (work / "work").mkdir(exist_ok=True)
    (work / "evidence").mkdir(exist_ok=True)
    if args["type"] == "bounty":
        (work / "submission").mkdir(exist_ok=True)

    target = args["target"]
    (work / "target.txt").write_text(target + "\n", encoding="utf-8")

    if GLOBAL_SCOPE.exists():
        shutil.copy2(GLOBAL_SCOPE, work / "scope_snapshot.yaml")
    if eng_scope_path.exists():
        shutil.copy2(eng_scope_path, work / "engagement_scope_snapshot.yaml")

    (work / "engagement.txt").write_text(engagement + "\n", encoding="utf-8")

    # Load the engagement scope to prefill program/program_url in bounty reports.
    # Fall back to the engagement name / empty string if the fields are absent.
    eng_scope_data = labutil.load_yaml_file(eng_scope_path) or {}
    eng_block = eng_scope_data.get("engagement", {}) if isinstance(eng_scope_data, dict) else {}
    program_name = ""
    program_url = ""
    if isinstance(eng_block, dict):
        program_name = eng_block.get("name", "") or engagement
        program_url = eng_block.get("program_url", "") or ""

    date_utc = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    category = args["category"] or cfg["default_category"]

    tmpl_dir = TEMPLATES_DIR / cfg["template_subdir"]

    log_template = tmpl_dir / cfg["log_template"]
    log_dest = work / cfg["log_filename"]
    if not log_dest.exists() and log_template.exists():
        replacements = {
            "CHALLENGE": args["name"],
            "TARGET": target or "unknown",
            "CATEGORY": category,
            "CTF_NAME": engagement,
            "DATE": date_utc,
            "SCOPE_CHECKED": scope_checked,
            "PROGRAM": program_name or args["name"],
            "PLATFORM": "hackerone",
            "PROGRAM_URL": program_url,
            "ENGAGEMENT": engagement,
            "PROJECT": args["name"],
            "REPO": "",
            "LOCAL_CLONE": "",
            "REPORTER": os.environ.get("USER", "agent"),
        }
        fill_template(log_template, log_dest, replacements)

    exploit_template = tmpl_dir / cfg["exploit_template"]
    exploit_dest = work / "work" / cfg["exploit_filename"]
    if not exploit_dest.exists() and exploit_template.exists():
        shutil.copy2(exploit_template, exploit_dest)
        exploit_dest.chmod(0o755)

    siblings_src = tmpl_dir / "endpoint_siblings.txt"
    if not siblings_src.exists():
        siblings_src = TEMPLATES_DIR / "ctf" / "endpoint_siblings.txt"
    siblings_dest = work / "work" / "endpoint_siblings.txt"
    if not siblings_dest.exists() and siblings_src.exists():
        shutil.copy2(siblings_src, siblings_dest)

    writeup_dest = work / cfg["writeup_filename"]
    if not writeup_dest.exists():
        if args["type"] == "ctf":
            writeup_dest.write_text(
                f"# {args['name']}\n\n"
                f"**CTF:** {engagement}\n"
                f"**Category:** {category}\n"
                f"**Target:** {target or 'unknown'}\n"
                f"**Status:** draft\n\n"
                f"## TL;DR\n\n## Exploit Chain\n\n## Evidence\n\n## Flag\n\n## Lessons\n",
                encoding="utf-8",
            )
        else:
            # T2-15: use fill_template for writeup templates too (was shutil.copy2,
            # which left {{...}} placeholders unfilled). Add missing keys with
            # empty defaults so the templates render cleanly.
            writeup_template = tmpl_dir / cfg["writeup_filename"].replace(".md", "_template.md")
            if not writeup_template.exists():
                writeup_template = tmpl_dir / ("report_h1.md" if args["type"] == "bounty" else "advisory_template.md" if args["type"] == "cve" else "")
            if writeup_template and writeup_template.exists() and writeup_template.is_file():
                # P2: YAML-escape scalar frontmatter values that are inserted
                # into double-quoted positions in report_h1.md (engagement,
                # program, program_url, title). A program name like Foo: Bar
                # or with embedded double-quotes would otherwise break or
                # change the generated frontmatter. INITIAL_LIVE_TARGET is a
                # list item, not a quoted scalar, so it's not escaped here.
                writeup_replacements = {
                    **replacements,
                    "VULN_CLASS": "",
                    "SEVERITY": "",
                    "TITLE": _yaml_scalar_escape(args["name"]),
                    "VENDOR": "",
                    "AFFECTED_VERSIONS": "",
                    "CVE_ID": "",
                    "CVSS_SCORE": "",
                    "PROGRAM_URL": _yaml_scalar_escape(program_url),
                    "ENGAGEMENT": _yaml_scalar_escape(engagement),
                    "PROGRAM": _yaml_scalar_escape(program_name or args["name"]),
                    # Bounty report_h1.md frontmatter prefilling. The template
                    # has `live_targets:\n  {{INITIAL_LIVE_TARGET}}` so we can
                    # inject either a `- <url>` entry or `[]` via simple replace.
                    # Unknown fields (asset_id, asset_name, weakness, severity,
                    # finding_type, attachments, testing) are left as the
                    # explicit-invalid placeholders from the template so a
                    # fresh workspace FAILS `lab-h1-report check` until the
                    # author fills them in.
                    "INITIAL_LIVE_TARGET": (
                        f"- {target}" if args["type"] == "bounty" and target else "[]"
                    ),
                }
                fill_template(writeup_template, writeup_dest, writeup_replacements)
            else:
                writeup_dest.write_text(
                    f"# {args['name']}\n\n"
                    f"**Type:** {args['type']}\n"
                    f"**Engagement:** {engagement}\n"
                    f"**Target:** {target or 'unknown'}\n"
                    f"**Status:** draft\n\n"
                    f"## Summary\n\n## Details\n\n## Evidence\n\n## Lessons\n",
                    encoding="utf-8",
                )

    FINDINGS_ROOT.mkdir(parents=True, exist_ok=True)
    # T2-07: use labutil.audit (json.dumps, safe) instead of %-formatting
    labutil.audit(
        "lab-new",
        target=target,
        engagement=engagement,
        exit_code=0,
        type=args["type"],
        name=args["name"],
    )

    print(f"\n[+] Workspace: {work}")
    print(f"[+] Mode: {ws_mode}")
    print(f"[+] Log: {work / cfg['log_filename']}")
    print(f"[+] {cfg['exploit_filename']}: {exploit_dest}")
    print(f"[+] Evidence dir: {work / 'evidence'}")
    print(f"[+] Engagement: {engagement}")
    print(f"\nNext: cd '{work}' && keep {cfg['log_filename']} current before running tools.")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
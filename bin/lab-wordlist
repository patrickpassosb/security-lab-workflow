#!/usr/bin/env python3
"""lab-wordlist — generate custom wordlists from target JS, wayback URLs, and HTML.

Merges endpoints from LinkFinder output, waybackurls, and HTML scraping
into a deduplicated wordlist optimized for directory/endpoint fuzzing on
the specific target. Better than generic SecLists because it's tailored
to the target's actual API surface.

Usage:
    lab-wordlist <url> [--output <path>]

Outputs a deduplicated wordlist to ./recon/custom-wordlist.txt (or --output path).
Sources:
  1. waybackurls <domain> — historical URLs for this domain
  2. LinkFinder endpoints (if recon/endpoints.txt exists from lab-firstpass)
  3. HTML scraping — extract paths from the page source
  4. gf urls pattern on any downloaded JS files
"""

from __future__ import annotations

import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from urllib.parse import urlparse

LAB = Path(os.environ.get("HACKING_LAB", os.path.expanduser("~/security-lab")))


def log(msg: str) -> None:
    ts = datetime.now(timezone.utc).strftime("%H:%M:%S")
    print(f"[{ts}] {msg}", flush=True)


def run(cmd: list[str], timeout: int = 30) -> tuple[int, str, str]:
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return result.returncode, result.stdout or "", result.stderr or ""
    except subprocess.TimeoutExpired:
        return 124, "", "TIMEOUT"
    except FileNotFoundError:
        return 127, "", f"Not found: {cmd[0]}"


def extract_paths(urls: list[str]) -> list[str]:
    """Extract path segments from URLs for wordlist."""
    paths = set()
    for url in urls:
        try:
            parsed = urlparse(url)
            path = parsed.path.strip("/")
            if not path:
                continue
            # Split into segments
            segments = path.split("/")
            for seg in segments:
                seg = seg.strip()
                if seg and not seg.startswith("?") and not seg.startswith("#") and len(seg) < 50:
                    # Skip file-like segments with extensions (except common web ones)
                    if "." in seg and not seg.endswith((".html", ".htm", ".php", ".js", ".json", ".xml")):
                        continue
                    paths.add(seg)
        except Exception:
            continue
    return sorted(paths)


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        return 1

    url = sys.argv[1]
    output_path = ""

    for i, arg in enumerate(sys.argv[2:], 2):
        if arg == "--output" and i + 1 < len(sys.argv):
            output_path = sys.argv[i + 1]
        elif arg.startswith("--output="):
            output_path = arg.split("=", 1)[1]

    # Determine output path
    if not output_path:
        cwd = Path.cwd()
        if (cwd / "recon").exists():
            output_path = str(cwd / "recon" / "custom-wordlist.txt")
        else:
            output_path = "./custom-wordlist.txt"

    # Extract domain
    parsed = urlparse(url if "://" in url else "//" + url)
    domain = parsed.hostname or url.split("/")[0]

    all_words: set[str] = set()

    # Source 1: waybackurls
    log(f"Source 1/3: waybackurls for {domain}")
    code, stdout, stderr = run(["waybackurls", domain], timeout=30)
    if code == 0 and stdout:
        urls = stdout.splitlines()
        paths = extract_paths(urls)
        all_words.update(paths)
        log(f"  -> {len(paths)} unique path segments from {len(urls)} wayback URLs")
    else:
        log(f"  -> waybackurls failed or empty (exit {code})")

    # Source 2: LinkFinder endpoints (if available from lab-firstpass)
    log("Source 2/3: LinkFinder endpoints")
    endpoints_file = Path.cwd() / "recon" / "endpoints.txt"
    if endpoints_file.exists():
        endpoints = endpoints_file.read_text().splitlines()
        paths = extract_paths(endpoints)
        all_words.update(paths)
        log(f"  -> {len(paths)} unique path segments from {len(endpoints)} endpoints")
    else:
        log("  -> No endpoints.txt found (run lab-firstpass first)")

    # Source 3: HTML scraping
    log("Source 3/3: HTML scraping")
    code, stdout, stderr = run(["curl", "-s", "-L", "-k", url], timeout=15)
    if code == 0 and stdout:
        # Extract paths from href/src attributes
        href_paths = re.findall(r'(?:href|src|action)=["\']([^"\']+)["\']', stdout)
        # Also extract API-like paths from inline JS
        api_paths = re.findall(r'["\']([/(][a-zA-Z0-9/_-]+)["\']', stdout)
        all_urls = href_paths + api_paths
        paths = extract_paths([url] if not url.startswith("http") else [url] for url in all_urls if url)
        # Simpler: just extract path-like strings
        for p in all_urls:
            if "/" in p and not p.startswith("http") and not p.startswith("//"):
                segments = p.strip("/").split("/")
                for seg in segments:
                    if seg and len(seg) < 50 and not seg.startswith("?"):
                        all_words.add(seg)
        log(f"  -> {len(all_words)} total unique words after HTML scraping")
    else:
        log(f"  -> HTML fetch failed (exit {code})")

    # Also add gf url patterns from JS files if available
    js_dir = Path.cwd() / "recon" / "js"
    if js_dir.exists():
        for js_file in js_dir.glob("*.js"):
            code, stdout, stderr = run(["gf", "urls"], timeout=10)
            if code == 0 and stdout:
                urls = stdout.splitlines()
                paths = extract_paths(urls)
                all_words.update(paths)

    # Write wordlist
    outpath = Path(output_path)
    outpath.parent.mkdir(parents=True, exist_ok=True)
    sorted_words = sorted(all_words)
    outpath.write_text("\n".join(sorted_words) + "\n", encoding="utf-8")

    log(f"")
    log(f"=== CUSTOM WORDLIST GENERATED ===")
    log(f"Output: {outpath}")
    log(f"Words: {len(sorted_words)}")
    log(f"Sources: waybackurls + LinkFinder + HTML scraping + gf patterns")
    log(f"")
    log(f"Use with ffuf:")
    log(f"  ffuf -u '{url}/FUZZ' -w {outpath} -mc 200,301,302,401,403 -t 20 -s")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
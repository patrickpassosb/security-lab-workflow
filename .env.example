# security-lab-workflow environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets stay local.

# Lab root directory (where you cloned/installed the framework)
HACKING_LAB="$HOME/security-lab"

# Obsidian vault directory (for the optional Obsidian plugin)
# Set this if you want session debriefs and CTF templates written to your vault
VAULT_DIR=""

# Caido CLI binary path (for the optional Caido integration)
# If caido-cli is on your PATH, leave this empty
CAIDO_CLI=""

# Caido mode skill directory (auto-detected if empty)
CAIDO_MODE_DIR=""

# jwt_tool directory (for JWT analysis)
# Defaults to $HACKING_LAB/tools/jwt_tool
JWT_TOOL_DIR=""

# Voyage AI API key (for the optional gbrain embeddings plugin)
# Get a free key at https://dash.voyageai.com/
VOYAGE_API_KEY=""

# Your GitHub username (for gh CLI operations)
GITHUB_USERNAME=""